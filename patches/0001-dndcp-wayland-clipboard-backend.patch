+ *
+ * Concrete CopyPasteDnDImpl for Wayland sessions. Implements copy/paste only
+ * (no drag and drop) and carries no X11/GTK dependency: it does not create a
+ * Gtk::Main or an X selection owner. The RPC transport runs on the toolbox
+ * GLib main loop, and the local clipboard is driven by CopyPasteUIWayland.
+ */
+
+#ifndef __COPYPASTEDNDWAYLAND_H__
+#define __COPYPASTEDNDWAYLAND_H__
+
+#include "vm_basic_types.h"
+#include "copyPasteDnDImpl.h"
+
