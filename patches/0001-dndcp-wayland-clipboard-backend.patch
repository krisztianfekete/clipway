+ * along with this program; if not, write to the Free Software Foundation, Inc.,
+ * 51 Franklin St, Fifth Floor, Boston, MA  02110-1301 USA.
+ *
+ *********************************************************/
+
+/**
+ * @file copyPasteUIWayland.cpp
+ *
+ * Wayland implementation of host<->guest copy/paste, derived from
+ * copyPasteUIX11.cpp. Rather than owning an X selection through GtkClipboard,
+ * the local clipboard is read and written by shelling out to the wl-clipboard
+ * utilities (wl-paste / wl-copy). Those use the wlr-data-control protocol,
+ * which works for an unfocused/windowless client - unlike the core
+ * wl_data_device protocol that GtkClipboard uses and that requires keyboard
+ * focus. This is what allows a background daemon to bridge the clipboard.
+ *
+ * Only plain UTF-8 text is supported.
+ */
+
+#define G_LOG_DOMAIN "dndcp"
+
+#include <glib.h>
+#include <errno.h>
+#include <string.h>
+#include <unistd.h>
+
+#include "vmware.h"
+#include "copyPasteUIWayland.h"
+#include "guestDnDCPMgr.hh"
+#include "dnd.h"
+#include "dndMsg.h"
+
+extern "C" {
+#include "dndClipboard.h"
+#include "dndCPMsgV4.h"
+}
+
+
+/*
+ *-----------------------------------------------------------------------------
+ *
+ * CopyPasteWaylandReapChild --
+ *
+ *    GChildWatch callback used to reap the (short-lived) foreground
+ *    wl-copy / wl-paste helper processes so they do not become zombies.
+ *
+ *-----------------------------------------------------------------------------
+ */
+
+static void
+CopyPasteWaylandReapChild(GPid pid,       // IN
+                          gint status,    // IN: unused
+                          gpointer data)  // IN: unused
+{
+   g_spawn_close_pid(pid);
+}
+
+
+/*
+ *-----------------------------------------------------------------------------
+ *
+ * CopyPasteWaylandSetText --
+ *
+ *    Push UTF-8 text onto the local Wayland clipboard by spawning wl-copy and
+ *    feeding the bytes to its stdin. wl-copy reads stdin until EOF, then forks
+ *    a resident daemon to serve the selection and the foreground process
+ *    exits; therefore we must close stdin after writing (the EOF) and must not
+ *    block waiting for it. The spawn inherits the environment so wl-copy sees
+ *    WAYLAND_DISPLAY / XDG_RUNTIME_DIR.
+ *
+ *-----------------------------------------------------------------------------
+ */
+
+static void
+CopyPasteWaylandSetText(const char *data,  // IN
+                        gsize len)         // IN
+{
+   const gchar *argv[] = {
+      "wl-copy", "--type", "text/plain;charset=utf-8", NULL
+   };
+   GPid pid = 0;
+   gint stdinFd = -1;
+   GError *err = NULL;
+   gsize off = 0;
+
+   if (!g_spawn_async_with_pipes(NULL, (gchar **) argv, NULL,
+            (GSpawnFlags) (G_SPAWN_SEARCH_PATH | G_SPAWN_DO_NOT_REAP_CHILD),
+            NULL, NULL, &pid, &stdinFd, NULL, NULL, &err)) {
+      g_warning("%s: failed to spawn wl-copy: %s\n", __FUNCTION__,
+                err != NULL ? err->message : "unknown error");
+      g_clear_error(&err);
+      return;
+   }
+
+   while (off < len) {
+      ssize_t written = write(stdinFd, data + off, len - off);
+      if (written < 0) {
+         if (errno == EINTR) {
+            continue;
+         }
+         g_warning("%s: write to wl-copy failed: %s\n", __FUNCTION__,
+                   g_strerror(errno));
+         break;
+      }
+      off += (gsize) written;
+   }
+
+   /* Closing stdin is the EOF that lets wl-copy daemonize. */
+   close(stdinFd);
+   g_child_watch_add(pid, CopyPasteWaylandReapChild, NULL);
+}
+
+
+/*
+ *-----------------------------------------------------------------------------
+ *
+ * CopyPasteWaylandGetText --
+ *
+ *    Read the local Wayland clipboard by running wl-paste and capturing its
+ *    stdout. Returns a newly allocated, NUL-terminated buffer (free with
+ *    g_free) and stores its length (excluding the terminator) in *outLen, or
+ *    NULL when the clipboard is empty / unreadable. wl-paste exits non-zero
+ *    when nothing is copied.
+ *
+ *    wl-paste returns promptly, so a synchronous spawn is acceptable here;
+ *    it runs from the toolbox GLib main loop.
+ *
+ *-----------------------------------------------------------------------------
+ */
+
+static gchar *
+CopyPasteWaylandGetText(gsize *outLen)  // OUT
+{
+   const gchar *argv[] = { "wl-paste", "--no-newline", NULL };
+   gchar *out = NULL;
+   gint status = 0;
+   GError *err = NULL;
+
+   *outLen = 0;
+
+   if (!g_spawn_sync(NULL, (gchar **) argv, NULL,
+                     (GSpawnFlags) G_SPAWN_SEARCH_PATH,
+                     NULL, NULL, &out, NULL, &status, &err)) {
+      g_debug("%s: failed to spawn wl-paste: %s\n", __FUNCTION__,
+              err != NULL ? err->message : "unknown error");
+      g_clear_error(&err);
+      g_free(out);
+      return NULL;
+   }
+
+   /*
+    * status is the raw wait() status on POSIX; a clean exit 0 is 0. wl-paste
+    * exits non-zero when the clipboard is empty, which is not an error for us.
+    */
+   if (status != 0) {
+      g_debug("%s: wl-paste exit status %d (clipboard likely empty)\n",
+              __FUNCTION__, status);
+      g_free(out);
+      return NULL;
+   }
+
+   *outLen = (out != NULL) ? strlen(out) : 0;
+   return out;
+}
+
+
+/*
+ *-----------------------------------------------------------------------------
+ *
+ * CopyPasteUIWayland::CopyPasteUIWayland --
+ *
+ *    Constructor.
+ *
+ *-----------------------------------------------------------------------------
+ */
+
+CopyPasteUIWayland::CopyPasteUIWayland()
+ : mCP(NULL),
+   mInited(false)
+{
+   GuestDnDCPMgr *p = GuestDnDCPMgr::GetInstance();
+   ASSERT(p);
+   mCP = p->GetCopyPasteMgr();
+   ASSERT(mCP);
+   CPClipboard_Init(&mClipboard);
+}
+
+
+/*
+ *-----------------------------------------------------------------------------
+ *
+ * CopyPasteUIWayland::~CopyPasteUIWayland --
+ *
+ *    Destructor.
+ *
+ *-----------------------------------------------------------------------------
+ */
+
+CopyPasteUIWayland::~CopyPasteUIWayland()
+{
+   CPClipboard_Destroy(&mClipboard);
+}
+
+
+/*
+ *-----------------------------------------------------------------------------
+ *
+ * CopyPasteUIWayland::Init --
+ *
+ *    Connect to the common-layer copy/paste signals. There is no GTK main
+ *    loop or X selection to set up; the RPC transport runs on the toolbox
+ *    GLib main loop.
+ *
+ *-----------------------------------------------------------------------------
+ */
+
+bool
+CopyPasteUIWayland::Init()
+{
+   if (mInited) {
+      return true;
+   }
+
+   mCP->srcRecvClipChanged.connect(
+      sigc::mem_fun(this, &CopyPasteUIWayland::GetRemoteClipboardCB));
+   mCP->destRequestClipChanged.connect(
+      sigc::mem_fun(this, &CopyPasteUIWayland::GetLocalClipboard));
+
+   mInited = true;
+   return true;
+}
+
+
+/*
+ *-----------------------------------------------------------------------------
+ *
+ * CopyPasteUIWayland::VmxCopyPasteVersionChanged --
+ *
+ *    Update version information in mCP.
+ *
+ *-----------------------------------------------------------------------------
+ */
+
+void
+CopyPasteUIWayland::VmxCopyPasteVersionChanged(RpcChannel *chan,  // IN: unused
+                                               uint32 version)    // IN
+{
+   ASSERT(mCP);
+   g_debug("%s: new version is %d\n", __FUNCTION__, version);
+   mCP->VmxCopyPasteVersionChanged(version);
+}
+
+
+/*
+ *-----------------------------------------------------------------------------
+ *
+ * CopyPasteUIWayland::GetRemoteClipboardCB --
+ *
+ *    Invoked when the host sends us clipboard contents. Extract the text item
+ *    and push it onto the local Wayland clipboard. host -> guest.
+ *
+ *-----------------------------------------------------------------------------
+ */
+
+void
+CopyPasteUIWayland::GetRemoteClipboardCB(const CPClipboard *clip)  // IN
+{
+   void *buf = NULL;
+   size_t sz = 0;
+
+   if (clip == NULL) {
+      g_debug("%s: no clipboard contents.\n", __FUNCTION__);
+      return;
+   }
+
+   if (CPClipboard_GetItem(clip, CPFORMAT_TEXT, &buf, &sz) &&
+       buf != NULL && sz > 0) {
+      /*
+       * CPFORMAT_TEXT is NUL-terminated UTF-8 and sz includes the terminator.
+       * Do not write the trailing NUL to the Wayland clipboard.
+       */
+      gsize len = (gsize) sz;
+      const char *text = (const char *) buf;
+
+      if (len > 0 && text[len - 1] == '\0') {
+         len--;
+      }
+      g_debug("%s: setting %" G_GSIZE_FORMAT " bytes of text on local clipboard\n",
+              __FUNCTION__, len);
+      CopyPasteWaylandSetText(text, len);
+   } else {
+      g_debug("%s: no text item in remote clipboard (text-only backend)\n",
+              __FUNCTION__);
+   }
+}
+
+
+/*
+ *-----------------------------------------------------------------------------
+ *
+ * CopyPasteUIWayland::GetLocalClipboard --
+ *
+ *    Retrieve the local clipboard text and send it to the host. Always sends
+ *    a clip back (empty when there is no text) so the host request does not
+ *    hang. guest -> host.
+ *
+ *-----------------------------------------------------------------------------
+ */
+
+void
+CopyPasteUIWayland::GetLocalClipboard(void)
+{
+   gsize len = 0;
+   gchar *text;
+   bool validDataInClip = false;
+
+   g_debug("%s: enter.\n", __FUNCTION__);
+
+   if (!mCP->IsCopyPasteAllowed()) {
+      g_debug("%s: copyPaste is not allowed\n", __FUNCTION__);
+      return;
+   }
+
+   CPClipboard_Clear(&mClipboard);
+
+   text = CopyPasteWaylandGetText(&len);
+   if (text != NULL && len > 0) {
+      if (!mCP->CheckCapability(DND_CP_CAP_PLAIN_TEXT_CP)) {
+         g_debug("%s: plain text copy/paste not in caps\n", __FUNCTION__);
+      } else if (!g_utf8_validate(text, len, NULL)) {
+         g_debug("%s: clipboard data is not valid UTF-8 text, skipping\n",
+                 __FUNCTION__);
+      } else if (len + 1 > (gsize) CPCLIPITEM_MAX_SIZE_V3) {
+         g_debug("%s: clipboard text too large (%" G_GSIZE_FORMAT " bytes)\n",
+                 __FUNCTION__, len);
+      } else if (CPClipboard_SetItem(&mClipboard, CPFORMAT_TEXT, text, len + 1)) {
+         validDataInClip = true;
+         g_debug("%s: got %" G_GSIZE_FORMAT " bytes of text\n", __FUNCTION__, len);
+      }
+   }
+   g_free(text);
+
+   if (validDataInClip) {
+      mCP->DestUISendClip(&mClipboard);
+   } else {
+      g_debug("%s: no text, sending empty clip back.\n", __FUNCTION__);
+      mCP->DestUISendClip(&mClipboard);
+   }
+}
